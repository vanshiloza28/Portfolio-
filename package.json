{
  "name": "vanshil-portfolio-root",
  "version": "1.0.0",
  "description": "Vanshil Oza Portfolio - Monorepo root",
  "scripts": {
    "install-backend": "npm install --prefix backend",
    "install-frontend": "npm install --production=false --prefix frontend",
    "build-frontend": "npm run build --prefix frontend",
    "build": "npm run install-backend && npm run install-frontend && npm run build-frontend",
    "start": "node backend/server.js"
  }
}
